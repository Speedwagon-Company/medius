# Runtime mode
APP_ENV=development

# Discord bot
DIS_BOT_TOKEN=""

# Database
DATABASE_URL="sqlite://bot.db"

# Payment provider
# - development: mock
# - production: must be a real provider implementation (mock is blocked)
PAYMENT_PROVIDER="mock"
PAYMENT_TIMEOUT_MINUTES=30
REQUIRED_CONFIRMATIONS=3

# Security / compliance boundaries
# Custodial mode is disabled by default.
# If ever enabled, legal/compliance approval flag must also be enabled.
CUSTODIAL_MODE=false
CUSTODIAL_MODE_APPROVED=false

# Payout profile encryption key (required).
# Use a Fernet key (recommended) or a 32-byte secret for local dev.
PAYOUT_ENCRYPTION_KEY=""

# Admin-only manual review accounts (comma-separated Discord user IDs)
ADMIN_DISCORD_IDS=""

# Mock provider controls (development/testing only)
MOCK_WEBHOOK_SECRET="replace-me"
MOCK_AUTO_COMPLETE_PAYOUT=true

# Legacy/deprecated direct wallet settings retained for compatibility only.
# Do not use direct private-key signing in production bot runtime.
RPC_URL=""
PRIVATE_WALLET_KEY=""
CHAINSTACK_WS=""
OWNER_WALLET=""
WEBHOOK_URL=""
