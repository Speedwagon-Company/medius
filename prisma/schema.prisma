// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src-ts/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  discordId String @unique
  username String

  sentTrades   Trade[] @relation("sender")
  receivedTrades Trade[] @relation("reciever")
}

enum TradeStatus {
  WAITING
  CONFIRMED
  CANCELLED
}

model Trade {
  id     Int    @id @default(autoincrement())
  channelId String @unique
  sender User? @relation(name: "sender", fields: [senderId], references: [discordId])
  reciever User? @relation(name: "reciever", fields: [recieverId], references: [discordId])
  recieverStatus TradeStatus @default(WAITING)
  senderStatus TradeStatus @default(WAITING)

  status TradeStatus @default(WAITING)
  selectedCoin String
  network String
  canCallSupport Boolean @default(false)

  senderId String?
  recieverId String?


}

model Config {
  id              Int    @id @default(autoincrement())
  embed_suc_color String
}
