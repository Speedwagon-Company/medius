// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src-ts/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  discordId String @unique
  username String

  sentTrades   Trade[] @relation("sender")
  sentInvites Invite[] @relation("inviteSender")
  receivedTrades Trade[] @relation("reciever")
  invites Invite[] @relation("target")
}

enum TradeStatus {
  WAITING
  CONFIRMED
  CANCELLED
  SUPPORT_REQUEST
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Invite {
  id Int @id @default(autoincrement())

  status InviteStatus @default(PENDING)
  target User @relation(name: "target", fields: [targetId], references: [discordId])
  targetId String

  sender User? @relation(name: "inviteSender", fields: [senderId], references: [discordId])
  senderId String?

  createdAt DateTime @default(now())
  }


model Trade {
  id     Int    @id @default(autoincrement())
  channelId String? @unique

  sender User? @relation(name: "sender", fields: [senderId], references: [discordId])
  reciever User? @relation(name: "reciever", fields: [recieverId], references: [discordId])
  recieverStatus TradeStatus @default(WAITING)
  senderStatus TradeStatus @default(WAITING)

  senderWallet String?
  recieverWallet String?

  status String  @default("WAITING")
  selectedCoin String
  network String
  calledSupport Boolean @default(false)

  received String?

  hideSender Boolean @default(false)
  hideReciever Boolean @default(false)

  senderId String?
  recieverId String?

  createdAt DateTime @default(now())

  membersId String?

}

model Config {
  id              Int    @id @default(autoincrement())
  guildId String? @unique

  publicLogChanId String?
  privateLogChanId String?
  adminRolesId String?
  mmWallet String?

  embed_suc_color String
}
