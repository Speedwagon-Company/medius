// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src-ts/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id Int @id @default(autoincrement())
  discordId String @unique
  username String

  sentTrades   Trade[] @relation("sender")
  receivedTrades Trade[] @relation("reciever")
}

enum TradeStatus {
  WAITING
  CONFIRMED
  CANCELLED
  SUPPORT_REQUEST
}

model Trade {
  id     Int    @id @default(autoincrement())
  channelId String @unique

  sender User? @relation(name: "sender", fields: [senderId], references: [discordId])
  reciever User? @relation(name: "reciever", fields: [recieverId], references: [discordId])
  recieverStatus TradeStatus @default(WAITING)
  senderStatus TradeStatus @default(WAITING)

  status String  @default("WAITING")
  selectedCoin String
  network String
  calledSupport Boolean @default(false)

  received String?
  
  hideSender Boolean @default(false)
  hideReciever Boolean @default(false)

  senderId String?
  recieverId String?

  createdAt DateTime @default(now())

}

model Config {
  id              Int    @id @default(autoincrement())
  guildId String? @unique

  publicLogChanId String?
  privateLogChanId String?

  embed_suc_color String
}
